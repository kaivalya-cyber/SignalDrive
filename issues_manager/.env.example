# --- Required: choose a provider ---
# Options: openai, anthropic, nvidia, openrouter, together, groq, deepseek
PROVIDER=openai

# --- Provider API Keys (set the one matching your provider) ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
NVIDIA_API_KEY=nvapi-...
OPENROUTER_API_KEY=sk-or-...
TOGETHER_API_KEY=...
GROQ_API_KEY=gsk_...
DEEPSEEK_API_KEY=sk-...

# --- Optional: override the default model ---
# Each provider has a sensible default, but you can override it here.
# GH_MANAGER_MODEL=gpt-4o-mini

# --- Optional: override API base URL ---
# GH_MANAGER_BASE_URL=https://integrate.api.nvidia.com/v1

# --- Optional: default GitHub repo ---
# GH_REPO=owner/repo

# --- Optional: max agent conversation turns ---
# GH_MANAGER_MAX_TURNS=20
